{
  "dashboard": {
    "id": null,
    "uid": "test-dash-001",
    "title": "TEST: Sample API Dashboard",
    "tags": ["test", "api"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "type": "timeseries",
        "title": "Request Rate",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus-uid"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "reqps"
          }
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Total Requests",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "sum(http_requests_total)",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus-uid"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "green"
                },
                {
                  "value": 1000,
                  "color": "red"
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "Response Time",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus-uid"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "s"
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "service",
          "type": "query",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          },
          "query": "label_values(http_requests_total, service)",
          "current": {
            "selected": false,
            "text": "api",
            "value": "api"
          },
          "multi": false,
          "includeAll": false
        }
      ]
    },
    "annotations": {
      "list": []
    },
    "links": [],
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "timepicker": {}
  }
}
